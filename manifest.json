{
  "manifest_version": 3,
  "name": "jdVidCat",
  "version": "1.0.0",
  "description": "Sniffs HLS and DASH video stream manifests and hands them off to JDownloader.",
  "permissions": [
    "webRequest",
    "storage",
    "notifications",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:9666/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "jdVidCat"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
